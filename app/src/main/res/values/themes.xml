<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.INS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->

        <!-- Define the overlays if not defined by default in Material Components -->
        <!-- For apps using Material Components, these might already be defined or inherited.
             However, explicitly defining them ensures they match your app's styling if needed. -->
    </style>

    <!-- AppBarOverlay: Used for the Toolbar itself -->
    <!-- This theme is applied to the AppBarLayout.
         It typically sets the color of the Toolbar and the color of its title and icons. -->
    <style name="Theme.INS.AppBarOverlay" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <!-- Example: If your Toolbar background is dark and you want light text/icons -->
        <!-- <item name="android:textColorPrimary">@android:color/white</item> -->
        <!-- <item name="android:textColorSecondary">@color/gray_300</item> -->
        <!-- <item name="colorControlNormal">@android:color/white</item> -->

        <!-- If your Toolbar is light (e.g., uses ?attr/colorSurface) and needs dark text/icons:
        <item name="android:textColorPrimary">@color/your_dark_text_color</item>
        <item name="colorControlNormal">@color/your_dark_icon_color</item>
        -->
    </style>

    <!-- PopupOverlay: Used for the Toolbar's overflow menu (the three dots) -->
    <!-- This theme is applied to the Toolbar's app:popupTheme attribute.
         It styles the background and text color of the popup menu. -->
    <style name="Theme.INS.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Light">
        <!-- Example: If you want a light popup menu with dark text -->
        <!-- <item name="android:background">@android:color/white</item> -->
        <!-- <item name="android:textColor">@color/your_dark_text_color</item> -->

        <!-- If you want a dark popup menu with light text:
        <item name="android:background">@color/your_dark_popup_background</item>
        <item name="android:textColor">@android:color/white</item>
        -->
    </style>

</resources>
