<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/owner_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".Owner"
    tools:openDrawer="start">

    <!-- Main content area -->
    <LinearLayout
        android:id="@+id/main_content_owner_linear"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Search Bar Container acting as top bar -->
        <LinearLayout
            android:id="@+id/o_autocomplete_container_top"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:background="?attr/colorPrimary"
            android:elevation="4dp">

            <ImageButton
                android:id="@+id/owner_hamburger_icon"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:src="@drawable/ic_menu_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Open navigation drawer"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>

            <AutoCompleteTextView
                android:id="@+id/o_autocomplete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:layout_weight="1"
                android:hint="Search location"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textColor="?attr/colorOnPrimary"
                android:textColorHint="?attr/colorOnPrimary"
                android:background="@null"
                android:inputType="textPostalAddress"
                android:maxLines="1"
                android:completionThreshold="2" />

            <Button
                android:id="@+id/btn_search_loc"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:textColor="?attr/colorOnPrimary"
                android:text="Search" />
        </LinearLayout>

        <!-- MapView and other content -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <org.osmdroid.views.MapView
                android:id="@+id/mapViewUser"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <Button
                android:id="@+id/location_specific_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add map"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="24dp"
                android:visibility="gone" />
        </RelativeLayout>

    </LinearLayout>

    <!-- Navigation Drawer Content -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/owner_nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true">

        <ScrollView
            android:id="@+id/nav_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="?attr/actionBarSize">

        <LinearLayout
            android:id="@+id/nav_linear_layout_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Work Summary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/nav_header_places_added"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1) Places Registered:"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/nav_ll_places_added_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/nav_header_floor_maps_added"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2) Floor Maps Uploaded:"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/nav_ll_floor_maps_added_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</ScrollView>
    </com.google.android.material.navigation.NavigationView>

    </androidx.drawerlayout.widget.DrawerLayout>
