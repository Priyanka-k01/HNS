<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- "From" Dropdown -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:hint="From">

        <AutoCompleteTextView
            android:id="@+id/from_dropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- "To" Dropdown -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:hint="To">

        <AutoCompleteTextView
            android:id="@+id/to_dropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            />

    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnSearchPath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Search Path"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"/>

    <!-- THIS IS THE REPLACEMENT: Using the custom PathfindingImageView class -->
    <java.com.example.ins.PathfindingImageView
        android:id="@+id/floorMapView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:contentDescription="Floor Map" />

    <Button
        android:id="@+id/btnStartIndoorNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Indoor Navigation"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        />

</LinearLayout>
